{
  "name": "triggrr",
  "version": "0.1.0",
  "description": "Multi-Tenant Event Automation & Notification Engine",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "worker": "tsx watch src/workers/index.ts",
    "worker:start": "node dist/workers/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "automation",
    "events",
    "webhooks",
    "multi-tenant"
  ],
  "license": "MIT",
  "dependencies": {
    "bullmq": "^5.70.1",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "ioredis": "^5.10.0",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
