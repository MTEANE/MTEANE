# ──────────────────────────────────────────────────────────────────────────────
# Triggrr — environment variables
# Copy this file to .env and fill in the values.
# On Fly.io, set these as secrets:  fly secrets set KEY=value
# ──────────────────────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development

# ── Neon PostgreSQL ────────────────────────────────────────────────────────────
# Dashboard → Project → Connection string  (choose "Node.js" driver)
# Format: postgresql://<user>:<password>@<host>/<dbname>?sslmode=require
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/triggrr?sslmode=require

# ── Upstash Redis ──────────────────────────────────────────────────────────────
# Dashboard → Database → Connect → ioredis  (copy the rediss:// URL)
# Format: rediss://default:<password>@<host>:<port>
REDIS_URL=rediss://default:your_upstash_token@lucky-lynx-12345.upstash.io:6379

# ── Auth ───────────────────────────────────────────────────────────────────────
# Secret used to sign/verify API keys — set to a long random string in production
API_KEY_SECRET=changeme-use-a-long-random-string-in-production
